{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@kolisachint/hoocode-ai": ["./packages/ai/src/index.ts"],
			"@kolisachint/hoocode-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@kolisachint/hoocode-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@kolisachint/hoocode-ai/dist/*": ["./packages/ai/src/*"],
			"@kolisachint/hoocode-agent-core": ["./packages/agent/src/index.ts"],
			"@kolisachint/hoocode-agent-core/*": ["./packages/agent/src/*"],
			"@kolisachint/hoocode-agent": ["./packages/coding-agent/src/index.ts"],
			"@kolisachint/hoocode-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@kolisachint/hoocode-agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@kolisachint/hoocode-tui": ["./packages/tui/src/index.ts"],
			"@kolisachint/hoocode-tui/*": ["./packages/tui/src/*"],
			"@kolisachint/hoocode-web-ui": ["./packages/web-ui/src/index.ts"],
			"@kolisachint/hoocode-web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
