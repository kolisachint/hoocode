{
	"name": "@kolisachint/hoocode-mini-lit",
	"version": "0.1.4",
	"description": "Lightweight Lit components with shadcn-inspired theming and Tailwind CSS integration. Vendored for HooCode from upstream mini-lit by Mario Zechner (MIT). Modifications under the same MIT terms.",
	"author": "Mario Zechner (original author); Sachin Koli (HooCode fork)",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"src/styles",
		"README.md",
		"llms.txt",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./dist/*": "./dist/*",
		"./styles/*": "./src/styles/*"
	},
	"dependencies": {
		"@preact/signals-core": "^1.12.1",
		"class-variance-authority": "^0.7.1",
		"diff": "^8.0.2",
		"highlight.js": "^11.11.1",
		"html-parse-string": "^0.0.9",
		"katex": "^0.16.22",
		"lucide": "^0.544.0",
		"marked": "^16.3.0",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"uhtml": "^5.0.9"
	},
	"peerDependencies": {
		"lit": "^3.3.1"
	},
	"scripts": {
		"clean": "echo 'Skipping clean - dist is pre-built'"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kolisachint/hoocode.git",
		"directory": "packages/mini-lit"
	},
	"devDependencies": {
		"shx": "^0.4.0"
	}
}
