{
  "version": "1.0",
  "active_mode": "build",
  "llm": {
    "default_provider": "anthropic",
    "providers": {
      "anthropic": { "api_key_env": "ANTHROPIC_API_KEY" },
      "openai": { "api_key_env": "OPENAI_API_KEY" }
    }
  },
  "modes": {
    "ask": { "auto_allow": ["read"] },
    "plan": { "auto_allow": ["read", "write"] },
    "build": { "auto_allow": ["read"] },
    "debug": { "auto_allow": ["read", "bash"] }
  }
}
