{
	"name": "@kolisachint/hoocode-ai",
	"version": "0.4.154",
	"description": "Unified LLM API with automatic model discovery and provider configuration",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./anthropic": {
			"types": "./dist/providers/anthropic.d.ts",
			"import": "./dist/providers/anthropic.js"
		},
		"./azure-openai-responses": {
			"types": "./dist/providers/azure-openai-responses.d.ts",
			"import": "./dist/providers/azure-openai-responses.js"
		},
		"./google": {
			"types": "./dist/providers/google.d.ts",
			"import": "./dist/providers/google.js"
		},
		"./google-vertex": {
			"types": "./dist/providers/google-vertex.d.ts",
			"import": "./dist/providers/google-vertex.js"
		},
		"./openai-codex-responses": {
			"types": "./dist/providers/openai-codex-responses.d.ts",
			"import": "./dist/providers/openai-codex-responses.js"
		},
		"./openai-completions": {
			"types": "./dist/providers/openai-completions.d.ts",
			"import": "./dist/providers/openai-completions.js"
		},
		"./openai-responses": {
			"types": "./dist/providers/openai-responses.d.ts",
			"import": "./dist/providers/openai-responses.js"
		},
		"./oauth": {
			"types": "./dist/oauth.d.ts",
			"import": "./dist/oauth.js"
		}
	},
	"bin": {
		"hoocode-ai": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"generate-models": "bun run scripts/generate-models.ts",
		"generate-image-models": "bun run scripts/generate-image-models.ts",
		"build": "tsgo -p tsconfig.build.json",
		"build:models": "npm run generate-models && npm run generate-image-models",
		"build:full": "npm run build:models && npm run build",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"dev:tsc": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"@google/genai": "^1.40.0",
		"typebox": "^1.1.24",
		"chalk": "^5.6.2",
		"openai": "6.26.0",
		"partial-json": "^0.1.7",
		"proxy-agent": "^6.5.0",
		"undici": "^7.19.1",
		"zod-to-json-schema": "^3.24.6"
	},
	"keywords": [
		"ai",
		"llm",
		"openai",
		"anthropic",
		"gemini",
		"bedrock",
		"unified",
		"api"
	],
	"author": "Mario Zechner (original author); Sachin Koli (HooCode fork)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kolisachint/hoocode.git",
		"directory": "packages/ai"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^24.3.0",
		"vitest": "^3.2.4"
	},
	"optionalDependencies": {
		"canvas": "^3.2.0"
	}
}
